# ECHO Protocol 环境变量配置
# 复制此文件为 .env 并填入你的配置

# ============================================
# ⚠️  安全警告
# 永远不要提交包含真实私钥的 .env 文件到 Git！
# .env 已在 .gitignore 中被忽略
# ============================================

# ECHO 雨娃部署钱包
# 地址: 0xD9B32068A1B316A5D26Ae50DADD7527F3a1fa3C2
# 用途: MEER 主网测试与部署
# 私钥存储位置: ~/.openclaw/workspace/.secrets/MEER_WALLET

# 部署钱包私钥（包含 0x 前缀）
# 示例: 0x1234567890abcdef...
PRIVATE_KEY=your_private_key_here

# Qitmeer 主网 RPC
QITMEER_RPC_URL=https://qng.rpc.qitmeer.io

# Qitmeer 测试网 RPC
QITMEER_TESTNET_RPC_URL=https://testnet-qng.rpc.qitmeer.io

# 区块浏览器 API（通常不需要修改）
QITMEER_EXPLORER_URL=https://qng.qitmeer.io

# 可选: 调试模式
DEBUG=false

# 可选: 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# ============================================
# IPFS 配置
# ============================================

# IPFS 提供商: pinata | infura | local
IPFS_PROVIDER=pinata

# --- Pinata 配置 ---
# 注册: https://pinata.cloud
# 在 API Keys 页面创建密钥
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
# 可选: Pinata JWT（用于高级功能）
# PINATA_JWT=your_pinata_jwt

# --- Infura IPFS 配置 ---
# 仅在 IPFS_PROVIDER=infura 时使用
# INFURA_IPFS_PROJECT_ID=your_infura_project_id
# INFURA_IPFS_PROJECT_SECRET=your_infura_project_secret

# --- 本地 IPFS 节点配置 ---
# 仅在 IPFS_PROVIDER=local 时使用
# IPFS_LOCAL_API_URL=http://localhost:5001
# IPFS_LOCAL_GATEWAY_URL=http://localhost:8080

# 主网关 URL（默认: https://gateway.pinata.cloud）
# IPFS_GATEWAY_URL=https://gateway.pinata.cloud

# 上传配置
# IPFS_MAX_FILE_SIZE=100  # MB
# IPFS_UPLOAD_TIMEOUT=300000  # ms (5分钟)
# IPFS_PIN=true
